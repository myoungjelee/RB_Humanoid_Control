# ===============================
# ROS WORKSPACE ENV
# ===============================

echo "----------------------------------------"
echo "[direnv] ROS workspace"

# ===============================
# 1. ROS BASE (underlay)
# ===============================
# → ROS2 기본 패키지들 (ros2, rclpy 등)
# → 이거 없으면 ros2 명령 자체가 안 됨
source /opt/ros/humble/setup.bash

echo "[direnv] ROS base loaded (humble)"


# ===============================
# 2. WORKSPACE OVERLAY
# ===============================
# → 내가 만든 패키지 등록
# → ros2 run / topic / node 인식됨
if [ -f ./install/setup.bash ]; then
    source ./install/setup.bash
    echo "[direnv] overlay loaded"
else
    echo "[direnv][WARN] install/setup.bash 없음 (colcon build 필요)"
fi


# ===============================
# 3. NETWORK CONFIG
# ===============================

# ROS_DOMAIN_ID
# → ROS 네트워크 그룹 (같은 값끼리만 통신)
export ROS_DOMAIN_ID=1

# ROS_LOCALHOST_ONLY
# → 1: 내 PC 내부만 통신 (디버깅 안정)
# → 0: 외부 PC/로봇과 통신 가능
export ROS_LOCALHOST_ONLY=1

echo "[direnv] DOMAIN=$ROS_DOMAIN_ID"
echo "[direnv] LOCALHOST_ONLY=$ROS_LOCALHOST_ONLY"

echo "----------------------------------------"
