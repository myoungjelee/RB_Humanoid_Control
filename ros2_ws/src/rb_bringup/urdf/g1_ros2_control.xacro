<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="g1_control_only">
  <!--
    control-only description derived from USD joint dump:
    - 실제 link/joint tree, joint type, axis, limits를 반영한다.
    - visual/collision mesh는 의도적으로 넣지 않는다.
    - ros2_control interface는 fixed joint를 제외한 37개 movable joint만 노출한다.
  -->

  <!--
    bridge 관련 값은 launch에서 주입한다.
    Step 1 skeleton 모드에서는 bridge_enabled=false,
    Step 2부터는 /rb/joint_states -> read(), /rb/command_raw -> write()를 연결한다.
  -->
  <xacro:arg name="bridge_enabled" default="false"/>
  <xacro:arg name="joint_state_topic" default="/rb/joint_states"/>
  <xacro:arg name="command_topic" default="/rb/command_raw"/>

  <xacro:macro name="stub_link" params="name">
    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.001"/>
        <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:macro name="ros2_control_joint" params="name">
    <joint name="${name}">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:macro>

  <!-- link definitions -->
  <xacro:stub_link name="head_link"/>
  <xacro:stub_link name="imu_link"/>
  <xacro:stub_link name="left_ankle_pitch_link"/>
  <xacro:stub_link name="left_ankle_roll_link"/>
