  <ros2_control name="G1ControlOnlySystem" type="system">
    <hardware>
      <plugin>rb_hardware_interface/RBHardwareSystem</plugin>
      <param name="bridge_enabled">$(arg bridge_enabled)</param>
      <param name="joint_state_topic">$(arg joint_state_topic)</param>
      <param name="command_topic">$(arg command_topic)</param>
    </hardware>

